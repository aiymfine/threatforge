# ThreatForge — AI-Powered Threat Modeling
# Copy this file to .env and fill in your values

# LLM Provider: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI (or OpenAI-compatible like Together AI, Groq, DeepInfra)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (free, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Server
PORT=3100
DATA_DIR=./data

# ── Security (optional) ──────────────────────────────────
# Set this to enable API authentication. All /api/* routes (except /api/health)
# will require this key as a Bearer token.
# TF_ADMIN_KEY=

# CORS — comma-separated allowed origins (default: allow all)
# For production: CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=
