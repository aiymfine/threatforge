{
  "name": "threatforge",
  "version": "1.0.0",
  "private": true,
  "description": "ThreatForge — AI-Powered Threat Modeling",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vitest": "^3.0.0"
  }
}
